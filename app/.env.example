# ─────────────────────────────────────────────────────────────────────────────
# React App — Vite Environment Variables
#
# These are injected at BUILD TIME by Vite (not at runtime).
# Only VITE_ prefixed variables are exposed to the browser bundle.
#
# For local development: copy to .env.local and edit
# For CI/CD: passed as --build-arg to docker build (see .gitlab-ci.yml)
#
# ⚠️  NEVER store secrets here — these values are embedded in the JS bundle
# ─────────────────────────────────────────────────────────────────────────────

# Application version (set by CI pipeline number)
VITE_APP_VERSION=v1.0.0

# Git commit SHA (set by CI — $CI_COMMIT_SHA)
VITE_COMMIT_SHA=local

# Build timestamp (set by CI — $(date -u +%Y-%m-%dT%H:%M:%SZ))
VITE_BUILD_TIME=

# Deployment environment label shown in the UI
VITE_ENVIRONMENT=local

# Kubernetes cluster name shown in the UI
VITE_CLUSTER_NAME=react-k8s-cluster
