# Copy to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars — it is gitignored.
#
# Sensitive variables go in .envrc (also gitignored):
#   export TF_VAR_grafana_admin_password="YourSecurePassword123!"
#   export TF_VAR_registry_username="your-deploy-token-username"
#   export TF_VAR_registry_password="your-deploy-token-password"
#   export TF_HTTP_USERNAME="your-gitlab-username"
#   export TF_HTTP_PASSWORD="your-personal-access-token"

cluster_name             = "react-k8s-cluster"
kubernetes_version       = "v1.32.0"
app_name                 = "react-app"
namespace                = "webapp"
ingress_host             = "webapp.local"
enable_catch_all_ingress = true
replicas                 = 2

# GitLab CE Container Registry path (no tag — CI appends :SHA)
# Format: GITLAB_CE_IP:5050/USERNAME/PROJECT_NAME/react-app
image_repository = "GITLAB_CE_IP:5050/YOUR_USERNAME/react-k8s-terraform-demo/react-app"

registry_host = "GITLAB_CE_IP:5050"
