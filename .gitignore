# ─── Terraform ────────────────────────────────────────────────────
**/.terraform/
**/terraform.tfstate
**/terraform.tfstate.backup
**/terraform.tfstate.*.backup
**/terraform.tfvars          # contains secrets — use .example instead
*.tfplan
.terraformrc
terraform.rc

# ─── Kubernetes / Secrets ─────────────────────────────────────────
kubeconfig
*.kubeconfig
*-kubeconfig
secrets/
*.secret

# ─── Node / React ─────────────────────────────────────────────────
app/node_modules/
app/dist/
app/.env
app/.env.*
!app/.env.example

# ─── macOS ────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ─── Editors ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ─── Logs ─────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ─── Misc ─────────────────────────────────────────────────────────
.env
.cache

# ─── Local secrets ────────────────────────────────────────────────
.envrc
*.bak
terraform/react-k8s-cluster-config
.helm-cache/
.helm-repositories.yaml
terraform/backend.hcl
# GKE kubeconfigs (all variants)
kubeconfig-gke*
# GCP SA keys
gke-ci-key.json
gke_gcloud_auth_plugin_cache

# Terraform local/sensitive files
terraform/*.tfvars
terraform/*.tfvars.json
terraform/gke-sa-key.json
