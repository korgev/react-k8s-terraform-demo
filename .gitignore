kubeconfig
*.kubeconfig
*-kubeconfig
secrets/
*.secret

# ─── Node / React ─────────────────────────────────────────────────
app/node_modules/
app/dist/
app/.env
app/.env.*
!app/.env.example

# ─── macOS ────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ─── Editors ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ─── Logs ─────────────────────────────────────────────────────────
*.log
npm-debug.log*

